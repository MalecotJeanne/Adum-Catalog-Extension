{
  "manifest_version": 3,
  "name": "AdumCatalogUpdates",
  "version": "1.1",
  "author": "Jeanne Malécot",
  "homepage_url": "https://github.com/MalecotJeanne/Adum-Catalog-Extension",

  "description": "Ajoute une section au catalogue avec les liens des formations ajoutées depuis la dernière visite.",

  "icons": {
    "48": "icons/icon.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://adum.fr/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://adum.fr/phd/formation/catalogue.pl"],
      "js": ["catalog_updates.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}